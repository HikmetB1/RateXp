# Local overrides for docker compose. Copy to .env (gitignored); every value
# here is also the built-in default, so an absent .env still works.
#   cp .env.example .env

# Host ports published on your machine.
CORE_HOST_PORT=8000
APP_HOST_PORT=8001

# Bundled PostgreSQL credentials (local only). Applied on first DB init; to
# change them on an existing stack, wipe the volume: docker compose down -v.
POSTGRES_USER=ratexp
POSTGRES_PASSWORD=ratexp
POSTGRES_DB=ratexp

# Connection string shared by core and app. Keep user/password in sync with the
# values above. Host is the compose service name `db`.
DATABASE_URL=postgresql://ratexp:ratexp@db:5432/ratexp

# Baked into /snippet so skills POST feedback back to core on the host.
RATEXP_SUBMIT_URL=http://localhost:8000/feedback

# PII redaction needs an Azure identity the local stack doesn't have, so it is
# off by default here (otherwise every consented transcript is dropped). Set to
# true only if you have Azure credentials and want to test real redaction.
RATEXP_REDACTION_ENABLED=false
