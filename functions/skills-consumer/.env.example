# Copy to .env and fill in. The function loads this file; real env vars override it.

# Model: a provider-prefixed id for LangChain's init_chat_model.
MODEL=openai:gpt-4o-mini
# MODEL=azure_openai:<your-deployment-name>

# OpenAI (when MODEL starts with openai:)
OPENAI_API_KEY=sk-...

# Azure OpenAI (when MODEL starts with azure_openai:)
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# OPENAI_API_VERSION=2024-10-21

# RateXp core to write to
RATEXP_CORE_URL=http://localhost:8000
